# 数据库连接地址。Foundation 阶段可选；后续接 PostgreSQL 时填写，例如 postgresql://user:pass@localhost:5432/word_format_agent
DATABASE_URL=

# Redis 连接地址。Foundation 阶段可选；后续接异步队列时填写，例如 redis://localhost:6379/0
REDIS_URL=

# 本地文件存储目录。必填/建议保留默认；用于保存上传 Word 原件、metadata.json、work 临时目录和 outputs 生成文件
FILE_STORAGE_ROOT=./storage

# LLM 服务商 API Key。当前 DOCX 格式化引擎不需要；后续 Agent 规则抽取/修正解释时必填，从所选模型服务商控制台获取
LLM_API_KEY=

# LLM 模型名称。当前 DOCX 格式化引擎不需要；后续 Agent 功能启用时必填，例如 gpt-5 或其他供应商模型名
LLM_MODEL=

# LibreOffice soffice 可执行文件路径。处理 legacy .doc 输入、PDF 导出或文档工具链 smoke check 时必填；本机通常为 /opt/homebrew/bin/soffice
SOFFICE_BIN=/opt/homebrew/bin/soffice

# 允许访问后端的前端地址。本地 Vite 默认使用以下两个地址；部署时替换为实际前端源
CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]
