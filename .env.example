# Word Format Agent backend/runtime environment.
# Copy to `.env` for local development. Do not commit `.env`.

# Application display name. Optional; defaults to "Word Format Agent" in code.
APP_NAME="Word Format Agent"

# API prefix used by FastAPI routers. Optional; current code defaults to /api.
API_PREFIX=/api

# Local file storage root. Required for uploads, metadata.json, work files, outputs, reports, and manifests.
# Default local commands run from backend/, so use ../storage.
FILE_STORAGE_ROOT=../storage

# LibreOffice soffice executable. Required for legacy .doc conversion and PDF export.
# macOS Homebrew default on this machine:
SOFFICE_BIN=/opt/homebrew/bin/soffice

# Allowed frontend origins for browser requests. Required when the frontend is not on the default Vite origin.
# The backend automatically appends local Vite fallback ports 5173-5199 for 127.0.0.1 and localhost.
CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]

# Database URL. Optional for current JSON-repository MVP.
# Production upgrade may use this for PostgreSQL, for example:
# postgresql://user:password@127.0.0.1:5432/word_format_agent
DATABASE_URL=

# Redis URL. Optional for current manual/local worker path.
# Production upgrade may use this for async queue orchestration, for example:
# redis://127.0.0.1:6379/0
REDIS_URL=

# LLM provider identifier for production Agent extraction and final layout review. Optional unless a Profile requires LLM.
# Example values: openai, anthropic, local
LLM_PROVIDER=

# OpenAI-compatible LLM service API base URL. Optional; leave blank for the default OpenAI API URL.
LLM_BASE_URL=

# LLM service API key. Optional for plain DOCX formatting.
# Required when using Agent rule extraction, style/rule document analysis, or Profiles with llm_final_review.required=true.
# Get this from the selected model provider console. Never commit a real key.
LLM_API_KEY=

# LLM model name. Optional for plain DOCX formatting.
# Required for Agent extraction and final layout review. Prefer a multimodal model if final layout review is enabled,
# because the backend may send PDF page images plus extracted text.
# Example: gpt-5 or a provider-specific multimodal model name.
LLM_MODEL=

# LLM request timeout in seconds. Required for longer rule documents when live Agent extraction is enabled.
# If this timeout is reached, requirement analysis fails visibly instead of falling back to a fake profile.
LLM_TIMEOUT_SECONDS=120

# LLM health-check timeout in seconds. Used by /api/health/llm and the frontend "检测 LLM" button.
# This check must receive real assistant content; an authenticated gateway that returns an empty event-stream is treated as unavailable.
LLM_HEALTH_TIMEOUT_SECONDS=15

# Production pipeline defaults. Not all are consumed by the current MVP yet; they document the next change boundary.

# Poll interval for a local worker loop in seconds.
WORKER_POLL_INTERVAL_SECONDS=2

# Maximum automatic quality-fix attempts before requiring manual review.
MAX_AUTO_FIX_ROUNDS=2

# Maximum uploaded file size in megabytes.
MAX_UPLOAD_MB=50

# Maximum number of Word documents accepted in one batch.
MAX_BATCH_FILES=10

# Default output formats requested by the production export pipeline.
DEFAULT_OUTPUT_FORMATS=docx,pdf

# Whether the production pipeline should auto-run quality reports after formatting.
QUALITY_GATE_ENABLED=true

# Whether the production pipeline should fail closed when unsupported checks remain.
FAIL_ON_UNSUPPORTED=true

# Directory names under FILE_STORAGE_ROOT for generated reports and delivery manifests.
REPORTS_DIR=reports
MANIFESTS_DIR=manifests
