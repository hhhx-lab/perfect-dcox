# Word Format Agent frontend environment.
# Copy to `frontend/.env.local` for local development. Do not commit `.env.local`.

# Backend API base URL used by the Vite frontend.
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Display name for future production UI surfaces.
VITE_APP_NAME=Word Format Agent

# Default polling interval for job, batch, extraction, and quality status refresh.
VITE_STATUS_POLL_INTERVAL_MS=2000

# 生产四步工作流 UI 开关。当前前端已经默认使用该工作流，保留此变量便于后续灰度。
VITE_ENABLE_PRODUCTION_WORKFLOW=true
